# ============================================
# ECommerce-IA — Variables d'environnement
# ============================================
# Copiez ce fichier en .env et adaptez les valeurs
#   cp .env.example .env
# ============================================

# --- Sécurité JWT ---
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_secure_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- API FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# --- Sécurité API ---
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=15

# --- Base de données PostgreSQL (Docker) ---
DB_PASSWORD=ecommerce_secure_2024
DATABASE_URL=postgresql://ecommerce:ecommerce_secure_2024@localhost:5432/ecommerce_ia

# --- HuggingFace (Chatbot RAG / Mistral) ---
# Obtenir sur https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_votre_cle_api_ici

# --- MLflow Tracking ---
MLFLOW_TRACKING_URI=./mlruns

# --- ChromaDB (Base vectorielle RAG) ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8080

# --- Frontend Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Kaggle API (téléchargement dataset) ---
KAGGLE_USERNAME=votre_username_kaggle
KAGGLE_KEY=votre_cle_kaggle

# --- Chemins modèles (optionnel) ---
MODEL_PATH=models/classification/efficientnet_b4_best.pth
CHROMA_DB_PATH=models/chatbot/chroma_db
RECOMMENDATION_MODEL_PATH=models/recommendation/svd_model.pkl
