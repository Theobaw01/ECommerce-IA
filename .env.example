# ============================================
# ECommerce-IA — .env (template)
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Base de données PostgreSQL
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_ia

# Authentification JWT
JWT_SECRET_KEY=votre_cle_secrete_jwt_ici
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# HuggingFace API (pour le chatbot Mistral)
HUGGINGFACE_API_KEY=hf_votre_cle_api_ici

# Google Maps API (pour la géolocalisation)
GOOGLE_MAPS_API_KEY=votre_cle_google_maps_ici

# Kaggle API (pour télécharger le dataset)
KAGGLE_USERNAME=votre_username_kaggle
KAGGLE_KEY=votre_cle_kaggle

# Configuration modèle
MODEL_PATH=models/classification/efficientnet_b4_best.pth
CHROMA_DB_PATH=models/chatbot/chroma_db
RECOMMENDATION_MODEL_PATH=models/recommendation/svd_model.pkl

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
